    "graphql:codegen": "graphql-codegen --config codegen.yml",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@apollo/client": "^3.7.6",
    "@remix-run/node": "^1.12.0",
    "@remix-run/react": "^1.12.0",
